rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default Deny
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    function userExists() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid));
    }

    function getUserData() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data;
    }

    function getRole() {
      return getUserData().role;
    }

    function getCompanyId() {
      return getUserData().companyId;
    }

    function isMemberOf(companyId) {
      return isSignedIn() && userExists() && getCompanyId() == companyId;
    }

    function isAdminOf(companyId) {
      return isMemberOf(companyId) && getRole() == 'ADMIN';
    }

    function isManagerOf(companyId) {
      return isMemberOf(companyId) && getRole() == 'MANAGER';
    }

    function isSalesOf(companyId) {
      return isMemberOf(companyId) && getRole() == 'SALESPERSON';
    }

    // Validation Blueprints
    function isValidUser(data) {
      return data.keys().hasAll(['companyId', 'email', 'role', 'name', 'status', 'createdAt']) &&
             data.companyId is string &&
             data.role in ['ADMIN', 'MANAGER', 'SALESPERSON', 'CUSTOMER'] &&
             data.status in ['active', 'inactive'];
    }

    function isValidCompany(data) {
      return data.keys().hasAll(['name', 'industries', 'ownerId', 'createdAt']) &&
             data.name is string && data.name.size() >= 2 && data.name.size() <= 100 &&
             data.industries is list && data.industries.size() > 0 &&
             data.ownerId == request.auth.uid;
    }

    function isValidOrder(data) {
      return data.keys().hasAll(['companyId', 'customerId', 'items', 'status', 'totalAmount', 'createdAt']) &&
             data.items is list && data.items.size() > 0 &&
             data.totalAmount is number && data.totalAmount >= 0;
    }

    // --- Collections ---

    // User Profiles
    match /users/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || (userExists() && getCompanyId() == resource.data.companyId));
      allow create: if isSignedIn() && isValidId(userId) && userId == request.auth.uid && (
        // Onboarding: Admin creating first profile
        (incoming().role == 'ADMIN' && existsAfter(/databases/$(database)/documents/companies/$(incoming().companyId))) ||
        // Admin of company creating another user
        (userExists() && getRole() == 'ADMIN' && getCompanyId() == incoming().companyId)
      );
      allow update: if isSignedIn() && (
        // User updating own profile (limited fields)
        (request.auth.uid == userId && incoming().diff(existing()).affectedKeys().hasAll(['name', 'mobile', 'status'])) ||
        // Admin of company
        (userExists() && getRole() == 'ADMIN' && getCompanyId() == existing().companyId)
      );
    }

    // Companies & Sub-collections
    match /companies/{companyId} {
      allow read: if isMemberOf(companyId);
      allow create: if isSignedIn() && isValidId(companyId) && isValidCompany(incoming()) &&
                    getAfter(/databases/$(database)/documents/users/$(request.auth.uid)).data.companyId == companyId;
      allow update: if isAdminOf(companyId);

      // Brands & Categories
      match /brands/{brandId} {
        allow read: if isMemberOf(companyId);
        allow write: if isAdminOf(companyId) || isManagerOf(companyId);
      }
      match /categories/{categoryId} {
        allow read: if isMemberOf(companyId);
        allow write: if isAdminOf(companyId) || isManagerOf(companyId);
      }

      // Products
      match /products/{productId} {
        allow read: if isMemberOf(companyId);
        allow write: if isAdminOf(companyId) || isManagerOf(companyId);
      }

      // Warehouse & Inventory
      match /warehouses/{warehouseId} {
        allow read: if isMemberOf(companyId);
        allow write: if isAdminOf(companyId) || isManagerOf(companyId);
      }
      match /inventory/{invId} {
        allow read: if isMemberOf(companyId);
        allow write: if isAdminOf(companyId) || isManagerOf(companyId);
      }

      // Customers
      match /customers/{customerId} {
        allow read: if isMemberOf(companyId);
        allow create: if isMemberOf(companyId) && (getRole() in ['ADMIN', 'MANAGER', 'SALESPERSON']);
        allow update: if isMemberOf(companyId) && (
          getRole() in ['ADMIN', 'MANAGER'] || 
          (getRole() == 'SALESPERSON' && existing().salespersonId == request.auth.uid)
        );
      }

      // Orders
      match /orders/{orderId} {
        allow read: if isMemberOf(companyId);
        allow create: if isMemberOf(companyId) && isValidOrder(incoming());
        allow update: if isMemberOf(companyId) && (
          isAdminOf(companyId) || isManagerOf(companyId) ||
          (isSalesOf(companyId) && existing().status == 'pending')
        ) && (
          // Status transitions only for managers/admins
          (getRole() in ['ADMIN', 'MANAGER'] && incoming().diff(existing()).affectedKeys().hasOnly(['status', 'updatedAt'])) ||
          // Minor edits for salespeople on pending orders
          (getRole() == 'SALESPERSON' && incoming().diff(existing()).affectedKeys().hasOnly(['items', 'totalAmount', 'updatedAt']))
        );
        allow delete: if isAdminOf(companyId) && existing().status == 'cancelled';
      }

      // Visits
      match /visits/{visitId} {
        allow read: if isMemberOf(companyId);
        allow create: if isSalesOf(companyId) || isManagerOf(companyId);
      }
    }
  }
}
